#!/bin/bash
# List Claude Code sessions sorted by last activity
#
# Usage:
#   claude-sessions          # List recent 20 sessions
#   claude-sessions -n 50    # List recent 50 sessions
#   claude-sessions -a       # List all sessions

LOGDIR="${CLAUDE_SESSION_HISTORY_DIR:-$HOME/.local/share/claude-session-history}/logs"

if [ ! -d "$LOGDIR" ]; then
    echo "No session history found in $LOGDIR"
    exit 0
fi

COUNT=20
while [ $# -gt 0 ]; do
    case "$1" in
        -n) COUNT="$2"; shift 2 ;;
        -a) COUNT=0; shift ;;
        --remove)
            TARGET="$2"
            if [ -z "$TARGET" ]; then
                echo "Usage: claude-sessions --remove <session_id>"
                exit 1
            fi
            FILE="$LOGDIR/${TARGET}.txt"
            if [ -f "$FILE" ]; then
                rm "$FILE"
                echo "Removed: $FILE"
            else
                echo "Not found: $FILE"
                exit 1
            fi
            exit 0
            ;;
        -h|--help)
            echo "Usage: claude-sessions [-n COUNT] [-a] [--remove SESSION_ID]"
            echo "  -n COUNT            Show last COUNT sessions (default: 20)"
            echo "  -a                  Show all sessions"
            echo "  --remove SESSION_ID Remove a session log"
            echo ""
            echo "Log directory: $LOGDIR"
            echo "Search logs:   rg 'keyword' $LOGDIR"
            exit 0
            ;;
        *) shift ;;
    esac
done

# Collect header info with file path, sort by last activity
for f in "$LOGDIR"/*.txt; do
    [ -f "$f" ] || continue
    HEADER=$(head -4 "$f")
    PERIOD=$(echo "$HEADER" | sed -n 's/^Period: //p')
    LAST=$(echo "$PERIOD" | sed 's/.*~ //')
    printf '%s\t%s\n' "$LAST" "$f"
done | sort -r | if [ "$COUNT" -gt 0 ]; then head -n "$COUNT"; else cat; fi | while IFS=$'\t' read -r _ FILE; do
    HEADER=$(head -4 "$FILE")
    SESSION=$(echo "$HEADER" | sed -n 's/^Session: //p')
    DIR=$(echo "$HEADER" | sed -n 's/^Directory: //p')
    PERIOD=$(echo "$HEADER" | sed -n 's/^Period: //p')
    FIRST=$(echo "$PERIOD" | sed 's/ ~ .*//')
    LAST=$(echo "$PERIOD" | sed 's/.*~ //')
    printf '%s ~ %s  %s  %s\n' "$LAST" "$FIRST" "$SESSION" "$DIR"
    FIRST_USER=$(grep '^❯ ' "$FILE" | grep -v -e '^❯ <' -e '^❯ /clear$' | head -1 | sed 's/^❯ //' | awk '{print substr($0, 1, 80)}')
    LAST_USER=$(grep '^❯ ' "$FILE" | grep -v '^❯ <' | tail -1 | sed 's/^❯ //' | awk '{print substr($0, 1, 80)}')
    LAST_ASST=$(grep '^● ' "$FILE" | tail -1 | sed 's/^● //' | awk '{print substr($0, 1, 80)}')
    [ -n "$FIRST_USER" ] && printf '  ❯ %s\n' "$FIRST_USER"
    [ -n "$FIRST_USER" ] && printf '  %s\n' "..."
    [ -n "$LAST_USER" ] && [ "$LAST_USER" != "$FIRST_USER" ] && printf '  ❯ %s\n' "$LAST_USER"
    [ -n "$LAST_ASST" ] && printf '  ● %s\n' "$LAST_ASST"
    echo
done
